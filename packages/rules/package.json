{
  "name": "@neoblock/rules",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsc -p tsconfig.json -w --preserveWatchOutput",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --ext .cjs,.js --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx test/engine.test.ts"
  },
  "dependencies": {
    "@neoblock/shared": "0.0.0"
  },
  "files": [
    "dist",
    "eslint",
    "tsconfig",
    "prettier.cjs",
    ".eslintrc.cjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./eslint/base": "./eslint/base.cjs",
    "./eslint/node": "./eslint/node.cjs",
    "./eslint/next": "./eslint/next.cjs",
    "./eslint/react": "./eslint/react.cjs",
    "./prettier": "./prettier.cjs",
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/node.json": "./tsconfig/node.json",
    "./tsconfig/next.json": "./tsconfig/next.json",
    "./tsconfig/react-library.json": "./tsconfig/react-library.json"
  }
}
